<UserControl x:Class="StudentInsight.Views.StudentExamLogs.ManageStudentExamLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F9FAFB"
             MinHeight="790"
             MinWidth="1000"
             MaxWidth="1024"
             MaxHeight="1330">

    <!-- Main Content -->
    <Grid Background="White"
          Margin="10">

        <!-- Grid Definitions -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==================================== CONTENT ==================================== -->

        <!-- Title -->
        <TextBlock Text="Manage Student Exam Logs"
                   FontSize="26"
                   FontWeight="Bold"
                   FontFamily="Segoe UI"
                   Foreground="#1E3A8A"/>

        <!-- Form -->
        <StackPanel Grid.Row="1"
                    Margin="0,10,0,0"
                    Orientation="Vertical"
                    VerticalAlignment="Top">

            <!-- Entries -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,10">

                <ComboBox Width="150"
                          Margin="5"
                          Text="Student"
                          ItemsSource="{Binding GetStudents}"
                          SelectedItem="{Binding SelectedStudent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id" />

                <ComboBox Width="150"
                          Margin="5"
                          Text="Exam"
                          ItemsSource="{Binding GetExams}"
                          SelectedItem="{Binding SelectedExam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id" />

                <ComboBox Width="150"
                          Margin="5"
                          Text="Status"
                          SelectedItem="{Binding SelectedDepartment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBox Width="150"
                         Margin="5"
                         Text="Obtained Marks"/>

                <TextBox Width="350"
                         Margin="5"
                         Text="Note"/>

            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,10">

                <Button Content="➕ Add Student Exam Log"
                        Background="DeepSkyBlue"
                        Foreground="Black"
                        Padding="5,2,5,2"
                        Command="{Binding AddStudentExamLog}"
                        Margin="5"/>

                <Button Content="🔼 Update Student Exam Log"
                        Background="Orange"
                        Foreground="Black"
                        Padding="5,2,5,2"
                        Command="{Binding UpdateStudentExamLog}"
                        Margin="5"/>

                <Button Content="❌ Delete Student Exam Log"
                        Background="OrangeRed"
                        Foreground="Black"
                        Padding="5,2,5,2"
                        Command="{Binding DeleteStudentExamLog}"
                        Margin="5"/>

                <Button Content="⧩ Filter Student Exam Logs"
                        Background="PaleGreen"
                        Foreground="Black"
                        Padding="5,2,5,2"
                        Command="{Binding FilterStudentExamLogs}"
                        Margin="5"/>

            </StackPanel>

            <!-- Data Grid -->
            <DataGrid ItemsSource="{Binding DataSource}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      Margin="0,10,0,0"
                      Background="#1E3A8A"
                      Foreground="AliceBlue"
                      Padding="2,2,2,2">

                <!-- Data Columns -->
                <DataGrid.Columns>

                    <DataGridTemplateColumn Header="Student Name"
                                            Width="*"
                                            CanUserResize="True"
                                            CanUserReorder="True"/>

                    <DataGridTemplateColumn Header="Department Name"
                                            Width="*"
                                            CanUserResize="True"
                                            CanUserReorder="True"/>

                    <DataGridTemplateColumn Header="Status"
                                            Width="*"
                                            CanUserResize="True"
                                            CanUserReorder="True"/>

                    <DataGridTemplateColumn Header="Obtained Marks"
                                            Width="*"
                                            CanUserResize="True"
                                            CanUserReorder="True"/>

                    <DataGridTemplateColumn Header="Note"
                                            Width="*"
                                            CanUserResize="True"
                                            CanUserReorder="True"/>

                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</UserControl>