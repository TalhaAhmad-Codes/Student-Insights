<Window x:Class="StudentInsight.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Student Insight"
        MinHeight="720" MinWidth="1280"
        MaxHeight="1080" MaxWidth="1920"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="250"/>
            <!-- Main Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= Sidebar ================= -->
        <Border Grid.Column="0" Background="#1E3A8A">
            <StackPanel>

                <!-- Profile Section -->
                <StackPanel Margin="20" HorizontalAlignment="Center">
                    <Ellipse Width="80" Height="80" Fill="White"/>
                    <TextBlock Text="{Binding Username}"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,10,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <Separator Margin="10" Background="#3B82F6"/>

                <!-- Navigation Buttons -->
                <StackPanel Margin="10">

                    <Button Content="Dashboard"
                            Style="{StaticResource SidebarButtonStyle}"/>
                    
                    <Button Content="Manage Students"
                            Style="{StaticResource SidebarButtonStyle}"/>

                    <Button Content="Manage Departments"
                            Style="{StaticResource SidebarButtonStyle}"/>

                    <Button Content="Manage Exams"
                            Style="{StaticResource SidebarButtonStyle}"/>

                    <Button Content="Manage Exam Logs"
                            Style="{StaticResource SidebarButtonStyle}"/>

                </StackPanel>

                <!-- Spacer -->
                <StackPanel Height="Auto" VerticalAlignment="Stretch"/>

                <Separator Margin="10" Background="#3B82F6"/>

                <!-- AI Services -->
                <Button Content="AI Service"
                        Margin="10"
                        Style="{StaticResource SidebarButtonStyle}"/>

                <!-- Account Settings -->
                <Button Content="Account Settings"
                        Margin="10"
                        Style="{StaticResource SidebarButtonStyle}"/>

            </StackPanel>
        </Border>

        <!-- ================= Main Content ================= -->
        <Grid Grid.Column="1" Background="White">
            <TextBlock Text="{Binding UserId}"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="#1E3A8A"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

    </Grid>
</Window>